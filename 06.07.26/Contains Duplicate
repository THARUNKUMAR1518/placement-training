class Solution {
    public boolean containsDuplicate(int[] nums) {
    int c=0;
    Arrays.sort(nums);
    for(int i=1;i<nums.length;i++)  {
        int temp=nums[i-1];
        if(temp==nums[i]){
            c++;
        }
    }
    if(c==0){
        return false;
    }
    else{
        return true;
    }
    }
}
